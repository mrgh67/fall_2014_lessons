getMSE = function(trainS, testS, train, test) {
for (dd in c(1,2)) {
for (sp in seq(0.2:1.0, by=0.1)) {
model = loess(train$Year ~ trainS, span=sp, degree=dd)
p=predict(model, newdata=testS)
nmse = calcMSE(p, test)
}
}
}
