getMSE = function(trainS, testS, tr, ts) {
mse=c()
for (dd in c(1,2)) {
for (sp in seq(0.2:1.0, by=0.1)) {
model = loess(tr$Year ~ trainS, span=sp, degree=dd)
p=predict(model, newdata=testS)
nmse = calcMSE(p, ts)
mse = c(mse, nmse)
}
}
return(mse)
}
