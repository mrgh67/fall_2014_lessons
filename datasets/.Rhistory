cat("len testS ", length(testS), "\n")
cat("len train ", length(train$Year), "\n")
cat("len test ", length(test$Year), "\n")
for (dd in c(1,2)) {
for (sp in seq(0.2:1.0, by=0.1)) {
model = loess(train$Year ~ trainS, span=sp, degree=dd)
